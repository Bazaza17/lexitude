# Lexitude environment template.
# Copy to .env.local and fill in. All values are required.

# ---- Anthropic ---------------------------------------------------------
# https://console.anthropic.com/ → Settings → API Keys
# Server-side only. Never prefix with NEXT_PUBLIC_.
ANTHROPIC_API_KEY=

# ---- GitHub ------------------------------------------------------------
# Fine-grained personal access token with public-repo read-only scope.
# Without this you'll hit GitHub's 60 req/hr unauthenticated rate limit
# after one or two audits. Server-side only.
# https://github.com/settings/personal-access-tokens/new
GITHUB_TOKEN=

# ---- Supabase ----------------------------------------------------------
# From your Supabase project: Settings → API.
# Publishable key (formerly "anon key") is safe to expose — it's intended
# to be embedded in the browser. Row-level security on the audit_runs
# table is what actually protects data. One-time schema setup lives in
# supabase/schema.sql.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
